# Port number
PORT=3002

# Node environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:usman123@localhost:5432/investware"

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
AUTH0_USER_PASSWORD=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# AWS Cognito (if using)
AWS_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=your-user-pool-id
AWS_COGNITO_CLIENT_ID=your-client-id

# Stripe (if using)
STRIPE_SECRET_KEY=your-stripe-secret-key

# CORS
CORS_ORIGIN=http://localhost:3001

# Log
LOG_FORMAT=dev
LOG_DIR=../logs

# Sentry (optional)
SENTRY_DSN=

# API
CREDENTIALS=true
